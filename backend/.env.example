# Copy this file to ".env" and fill in real values as you wire each system up.
# Any value left BLANK keeps that source on mock data — so you can go live one
# system at a time. Never commit the real .env to git.

# --- Centric (recipes, BOMs, yields, material master) ---
CENTRIC_BASE_URL=
CENTRIC_TOKEN=

# --- ERP (live stock levels) ---
ERP_BASE_URL=
ERP_API_KEY=

# --- Power BI (push destination for the purchasing dashboard) ---
POWERBI_PUSH_URL=
